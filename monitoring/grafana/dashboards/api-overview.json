{
  "title": "Roinet CRM — API Overview",
  "uid": "roinet-api-overview",
  "tags": ["roinet", "api"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Requests (last 3h)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": "Loki",
      "targets": [{
        "expr": "sum(count_over_time({job=\"roinet-api\", context=\"HTTP\"}[3h]))",
        "legendFormat": "Requests"
      }],
      "options": { "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "5xx Errors (last 3h)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": "Loki",
      "targets": [{
        "expr": "sum(count_over_time({job=\"roinet-api-errors\"}[3h]))",
        "legendFormat": "Errors"
      }],
      "options": { "colorMode": "background", "graphMode": "none",
        "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Security Events (last 3h)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": "Loki",
      "targets": [{
        "expr": "sum(count_over_time({job=\"roinet-api\", security=\"true\"}[3h]))",
        "legendFormat": "401/403"
      }],
      "options": { "colorMode": "background", "graphMode": "none",
        "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }] }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Slow Requests >1s (last 3h)",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": "Loki",
      "targets": [{
        "expr": "sum(count_over_time({job=\"roinet-api\", slow=\"true\"}[3h]))",
        "legendFormat": "Slow"
      }],
      "options": { "colorMode": "background", "graphMode": "none",
        "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }] }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request Rate (per minute)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "sum(rate({job=\"roinet-api\", context=\"HTTP\"}[1m]))",
          "legendFormat": "Total req/s"
        },
        {
          "expr": "sum(rate({job=\"roinet-api-errors\"}[1m]))",
          "legendFormat": "Errors/s"
        },
        {
          "expr": "sum(rate({job=\"roinet-api\", slow=\"true\"}[1m]))",
          "legendFormat": "Slow req/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Requests by HTTP Method",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "sum by (method) (rate({job=\"roinet-api\", context=\"HTTP\"}[1m]))",
          "legendFormat": "{{method}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Live API Logs",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 10 },
      "datasource": "Loki",
      "targets": [{
        "expr": "{job=\"roinet-api\"}",
        "legendFormat": ""
      }],
      "options": { "showTime": true, "showLabels": true, "sortOrder": "Descending", "wrapLogMessage": true }
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Errors Only",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 8 },
      "datasource": "Loki",
      "targets": [{
        "expr": "{job=\"roinet-api-errors\"}",
        "legendFormat": ""
      }],
      "options": { "showTime": true, "showLabels": true, "sortOrder": "Descending", "wrapLogMessage": true }
    },
    {
      "id": 9,
      "type": "logs",
      "title": "Security Events (401 / 403)",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 8 },
      "datasource": "Loki",
      "targets": [{
        "expr": "{job=\"roinet-api\", security=\"true\"}",
        "legendFormat": ""
      }],
      "options": { "showTime": true, "showLabels": false, "sortOrder": "Descending", "wrapLogMessage": true }
    },
    {
      "id": 10,
      "type": "logs",
      "title": "Slow Requests (>1 second)",
      "gridPos": { "x": 0, "y": 38, "w": 24, "h": 8 },
      "datasource": "Loki",
      "targets": [{
        "expr": "{job=\"roinet-api\", slow=\"true\"}",
        "legendFormat": ""
      }],
      "options": { "showTime": true, "showLabels": false, "sortOrder": "Descending", "wrapLogMessage": true }
    },
    {
      "id": 11,
      "type": "logs",
      "title": "Auth Events (login / logout / SSO)",
      "gridPos": { "x": 0, "y": 46, "w": 24, "h": 8 },
      "datasource": "Loki",
      "targets": [{
        "expr": "{job=\"roinet-api\", context=~\"AuthService|SsoService\"}",
        "legendFormat": ""
      }],
      "options": { "showTime": true, "showLabels": false, "sortOrder": "Descending", "wrapLogMessage": true }
    },
    {
      "id": 12,
      "type": "logs",
      "title": "Audit Trail (mutating operations)",
      "gridPos": { "x": 0, "y": 54, "w": 24, "h": 8 },
      "datasource": "Loki",
      "targets": [{
        "expr": "{job=\"roinet-api\", context=\"Audit\"}",
        "legendFormat": ""
      }],
      "options": { "showTime": true, "showLabels": false, "sortOrder": "Descending", "wrapLogMessage": true }
    },
    {
      "id": 13,
      "type": "logs",
      "title": "Slow DB Queries (>500ms)",
      "gridPos": { "x": 0, "y": 62, "w": 24, "h": 8 },
      "datasource": "Loki",
      "targets": [{
        "expr": "{job=\"roinet-api\", context=\"PrismaService\"} |= \"Slow DB query\"",
        "legendFormat": ""
      }],
      "options": { "showTime": true, "showLabels": false, "sortOrder": "Descending", "wrapLogMessage": true }
    },
    {
      "id": 14,
      "type": "logs",
      "title": "OTP Events",
      "gridPos": { "x": 0, "y": 70, "w": 24, "h": 8 },
      "datasource": "Loki",
      "targets": [{
        "expr": "{job=\"roinet-api\", context=\"OtpService\"}",
        "legendFormat": ""
      }],
      "options": { "showTime": true, "showLabels": false, "sortOrder": "Descending", "wrapLogMessage": true }
    }
  ]
}
