{
  "title": "Roinet CRM — UX Telemetry",
  "uid": "roinet-ux-telemetry",
  "tags": ["roinet", "ux", "telemetry"],
  "timezone": "utc",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "hide": 0,
        "name": "DS_LOKI",
        "type": "datasource",
        "pluginId": "loki",
        "query": "loki",
        "current": { "text": "Loki", "value": "roinet-loki" }
      },
      {
        "hide": 0,
        "name": "event_type",
        "type": "custom",
        "query": "pageview,click,hover_dwell,scroll_depth,rage_click,dead_click,form_focus,form_blur",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "hide": 0,
        "name": "userId",
        "type": "query",
        "datasource": { "type": "loki", "uid": "roinet-loki" },
        "query": "label_values({job=\"roinet-ux\"}, userId)",
        "multi": false,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total UX Events (period)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "roinet-loki" },
      "targets": [{ "expr": "sum(count_over_time({job=\"roinet-ux\", userId=~\"$userId\"}[$__range]))", "legendFormat": "Events" }],
      "options": { "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Rage Clicks",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "roinet-loki" },
      "targets": [{ "expr": "sum(count_over_time({job=\"roinet-ux\", event_type=\"rage_click\", userId=~\"$userId\"}[$__range]))", "legendFormat": "Rage Clicks" }],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 10 }] }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Dead Clicks",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "roinet-loki" },
      "targets": [{ "expr": "sum(count_over_time({job=\"roinet-ux\", event_type=\"dead_click\", userId=~\"$userId\"}[$__range]))", "legendFormat": "Dead Clicks" }],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Hover Dwells (>1.5s)",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "roinet-loki" },
      "targets": [{ "expr": "sum(count_over_time({job=\"roinet-ux\", event_type=\"hover_dwell\", userId=~\"$userId\"}[$__range]))", "legendFormat": "Hover Dwells" }],
      "options": { "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Unique Users",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "roinet-loki" },
      "targets": [{ "expr": "count(count by (userId) (count_over_time({job=\"roinet-ux\"}[$__range])))", "legendFormat": "Users" }],
      "options": { "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Events Over Time",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "roinet-loki" },
      "targets": [
        { "expr": "sum by (event_type) (count_over_time({job=\"roinet-ux\", event_type=~\"$event_type\", userId=~\"$userId\"}[1m]))", "legendFormat": "{{event_type}}" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } }
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Top Rage-Click Targets",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "roinet-loki" },
      "targets": [{
        "expr": "topk(20, sum by (target, page) (count_over_time({job=\"roinet-ux\", event_type=\"rage_click\", userId=~\"$userId\"}[$__range])))",
        "legendFormat": "{{page}} — {{target}}"
      }],
      "options": { "sortBy": [{ "displayName": "Value", "desc": true }] }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Top Dead-Click Hotspots",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "roinet-loki" },
      "targets": [{
        "expr": "topk(20, sum by (target, page) (count_over_time({job=\"roinet-ux\", event_type=\"dead_click\", userId=~\"$userId\"}[$__range])))",
        "legendFormat": "{{page}} — {{target}}"
      }],
      "options": { "sortBy": [{ "displayName": "Value", "desc": true }] }
    },
    {
      "id": 9,
      "type": "table",
      "title": "Highest Hover-Dwell Targets (users stuck)",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "roinet-loki" },
      "targets": [{
        "expr": "topk(20, sum by (target, page) (count_over_time({job=\"roinet-ux\", event_type=\"hover_dwell\", userId=~\"$userId\"}[$__range])))",
        "legendFormat": "{{page}} — {{target}}"
      }],
      "options": { "sortBy": [{ "displayName": "Value", "desc": true }] }
    },
    {
      "id": 10,
      "type": "barchart",
      "title": "Page Views by Page",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "roinet-loki" },
      "targets": [{
        "expr": "topk(15, sum by (page) (count_over_time({job=\"roinet-ux\", event_type=\"pageview\", userId=~\"$userId\"}[$__range])))",
        "legendFormat": "{{page}}"
      }],
      "options": { "orientation": "horizontal" }
    },
    {
      "id": 11,
      "type": "logs",
      "title": "UX Event Stream (filtered)",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "roinet-loki" },
      "targets": [{
        "expr": "{job=\"roinet-ux\", event_type=~\"$event_type\", userId=~\"$userId\"}"
      }],
      "options": { "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true }
    }
  ]
}
