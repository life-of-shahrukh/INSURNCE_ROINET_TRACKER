{
  "title": "Roinet CRM — UX Telemetry",
  "uid": "roinet-ux-telemetry",
  "tags": ["roinet", "ux", "telemetry"],
  "timezone": "utc",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "hide": 0,
        "name": "DS_LOKI",
        "type": "datasource",
        "pluginId": "loki",
        "query": "loki",
        "current": { "text": "Loki", "value": "roinet-loki" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total UX Events (period)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "roinet-loki" },
      "targets": [{ "expr": "sum(count_over_time({job=\"roinet-ux\"}[$__range]))", "legendFormat": "Events" }],
      "options": { "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Rage Clicks",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "roinet-loki" },
      "targets": [{ "expr": "sum(count_over_time({job=\"roinet-ux\"} |= `\"rage_click\"` [$__range]))", "legendFormat": "Rage Clicks" }],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 10 }] }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Dead Clicks",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "roinet-loki" },
      "targets": [{ "expr": "sum(count_over_time({job=\"roinet-ux\"} |= `\"dead_click\"` [$__range]))", "legendFormat": "Dead Clicks" }],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Hover Dwells (>1.5s)",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "roinet-loki" },
      "targets": [{ "expr": "sum(count_over_time({job=\"roinet-ux\"} |= `\"hover_dwell\"` [$__range]))", "legendFormat": "Hover Dwells" }],
      "options": { "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Unique Users",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "roinet-loki" },
      "targets": [{ "expr": "count(count by (userId) (count_over_time({job=\"roinet-ux\", userId!=\"\"}[$__range])) or count by (message_userId) (count_over_time({job=\"roinet-ux\"} | json | message_userId!=\"\" [$__range])))", "legendFormat": "Users" }],
      "options": { "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Events Over Time",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "roinet-loki" },
      "targets": [
        { "expr": "sum(rate({job=\"roinet-ux\"} |= `\"pageview\"` [2m]))", "legendFormat": "pageview" },
        { "expr": "sum(rate({job=\"roinet-ux\"} |= `\"click\"` !~ `\"rage_click|dead_click\"` [2m]))", "legendFormat": "click" },
        { "expr": "sum(rate({job=\"roinet-ux\"} |= `\"rage_click\"` [2m]))", "legendFormat": "rage_click" },
        { "expr": "sum(rate({job=\"roinet-ux\"} |= `\"dead_click\"` [2m]))", "legendFormat": "dead_click" },
        { "expr": "sum(rate({job=\"roinet-ux\"} |= `\"hover_dwell\"` [2m]))", "legendFormat": "hover_dwell" },
        { "expr": "sum(rate({job=\"roinet-ux\"} |= `\"scroll_depth\"` [2m]))", "legendFormat": "scroll_depth" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } }
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Top Rage-Click Targets",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "roinet-loki" },
      "targets": [
        {
          "expr": "topk(20, sum by (target, page) (count_over_time({job=\"roinet-ux\"} |= `\"rage_click\"` | json [$__range])))",
          "legendFormat": "{{page}} — {{target}}"
        },
        {
          "expr": "topk(20, sum by (message_target, message_page) (count_over_time({job=\"roinet-ux\"} |= `\"rage_click\"` | json [$__range])))",
          "legendFormat": "{{message_page}} — {{message_target}}"
        }
      ],
      "options": { "sortBy": [{ "displayName": "Value", "desc": true }] }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Top Dead-Click Hotspots",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "roinet-loki" },
      "targets": [
        {
          "expr": "topk(20, sum by (target, page) (count_over_time({job=\"roinet-ux\"} |= `\"dead_click\"` | json [$__range])))",
          "legendFormat": "{{page}} — {{target}}"
        },
        {
          "expr": "topk(20, sum by (message_target, message_page) (count_over_time({job=\"roinet-ux\"} |= `\"dead_click\"` | json [$__range])))",
          "legendFormat": "{{message_page}} — {{message_target}}"
        }
      ],
      "options": { "sortBy": [{ "displayName": "Value", "desc": true }] }
    },
    {
      "id": 9,
      "type": "table",
      "title": "Highest Hover-Dwell Targets (users stuck)",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "roinet-loki" },
      "targets": [
        {
          "expr": "topk(20, sum by (target, page) (count_over_time({job=\"roinet-ux\"} |= `\"hover_dwell\"` | json [$__range])))",
          "legendFormat": "{{page}} — {{target}}"
        },
        {
          "expr": "topk(20, sum by (message_target, message_page) (count_over_time({job=\"roinet-ux\"} |= `\"hover_dwell\"` | json [$__range])))",
          "legendFormat": "{{message_page}} — {{message_target}}"
        }
      ],
      "options": { "sortBy": [{ "displayName": "Value", "desc": true }] }
    },
    {
      "id": 10,
      "type": "barchart",
      "title": "Page Views by Page",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "roinet-loki" },
      "targets": [
        {
          "expr": "topk(15, sum by (page) (count_over_time({job=\"roinet-ux\"} |= `\"pageview\"` | json [$__range])))",
          "legendFormat": "{{page}}"
        },
        {
          "expr": "topk(15, sum by (message_page) (count_over_time({job=\"roinet-ux\"} |= `\"pageview\"` | json [$__range])))",
          "legendFormat": "{{message_page}}"
        }
      ],
      "options": { "orientation": "horizontal" }
    },
    {
      "id": 11,
      "type": "logs",
      "title": "UX Event Stream",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "roinet-loki" },
      "targets": [{ "expr": "{job=\"roinet-ux\"}" }],
      "options": { "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true }
    }
  ]
}
