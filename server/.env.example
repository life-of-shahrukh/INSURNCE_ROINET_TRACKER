# Copy to .env and fill in values — never commit .env

# ── Database (SQL Server) ────────────────────────────────────────────────────
# Local dev (SQL Server in Docker or local install):
DATABASE_URL="sqlserver://localhost:1433;database=roinet_crm;user=sa;password=YOUR_SA_PASSWORD;trustServerCertificate=true"

# AWS RDS SQL Server (publicly accessible):
# DATABASE_URL="sqlserver://<rds-endpoint>:1433;database=roinet_crm;user=<db_username>;password=<db_password>;encrypt=true;trustServerCertificate=false"

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET="change_me_to_a_long_random_secret_for_production_use_only"

# ── Server ──────────────────────────────────────────────────────────────────
# Keep on 8000 so it never collides with Next.js (3000 / 3001)
PORT=8000

# ── CORS ────────────────────────────────────────────────────────────────────
# Additional frontend origin beyond localhost:3000 and 3001 (e.g. production URL)
# Example: FRONTEND_URL=https://crm.roinet.in
FRONTEND_URL=http://localhost:3000

# ── External API (Cognitensor) ───────────────────────────────────────────────
# true  → reads from server/data/snapshots/ (no VPN needed — use for local dev)
# false → calls https://uatserviceapi.roinet.in live (requires VPN / UAT network)
USE_EXTERNAL_API_SNAPSHOT=true

# ── SSO (Central Roinet SSO Server) ─────────────────────────────────────────
# Shared API key — only the central SSO server should know this value.
# The SSO server must include this as the X-Sso-Api-Key header when calling
# POST /api/v1/sso/get-redirect-uri.
SSO_API_KEY="change_me_to_a_long_random_secret"

# RSA key pair used to sign and verify short-lived SSO tokens.
# Generate with:
#   openssl genrsa -out sso_private.pem 2048
#   openssl rsa -in sso_private.pem -pubout -out sso_public.pem
# Then paste the PEM contents below, replacing literal newlines with \n.
# Example (single-line format):
#   SSO_RSA_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"
SSO_RSA_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nREPLACE_ME\n-----END RSA PRIVATE KEY-----"
SSO_RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----"

# How long the SSO token is valid (in seconds). Default: 300 (5 minutes).
# The user must complete the redirect within this window.
SSO_TOKEN_EXPIRY_SECONDS=300

# Base URL of the frontend that users will be redirected to after SSO.
# The redirect URI will be: {SSO_REDIRECT_BASE_URL}/sso/callback?token=...
SSO_REDIRECT_BASE_URL=https://roinetinsurance.in
