# Copy to .env and fill in values — never commit .env

# ── Database (SQL Server) ────────────────────────────────────────────────────
# Local dev (SQL Server in Docker or local install):
DATABASE_URL="sqlserver://localhost:1433;database=roinet_crm;user=sa;password=YOUR_SA_PASSWORD;trustServerCertificate=true"

# AWS RDS SQL Server (publicly accessible):
# DATABASE_URL="sqlserver://<rds-endpoint>:1433;database=roinet_crm;user=<db_username>;password=<db_password>;encrypt=true;trustServerCertificate=false"

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET="change_me_to_a_long_random_secret_for_production_use_only"

# ── Server ──────────────────────────────────────────────────────────────────
# Keep on 8000 so it never collides with Next.js (3000 / 3001)
PORT=8000

# ── CORS ────────────────────────────────────────────────────────────────────
# Additional frontend origin beyond localhost:3000 and 3001 (e.g. production URL)
# Example: FRONTEND_URL=https://crm.roinet.in
FRONTEND_URL=http://localhost:3000

# ── External API (Cognitensor) ───────────────────────────────────────────────
# true  → reads from server/data/snapshots/ (no VPN needed — use for local dev)
# false → calls https://uatserviceapi.roinet.in live (requires VPN / UAT network)
USE_EXTERNAL_API_SNAPSHOT=true
