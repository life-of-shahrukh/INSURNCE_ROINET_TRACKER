generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Posp {
  id        String   @id @default(cuid()) @db.NVarChar(36)
  name      String   @db.NVarChar(200)
  code      String   @unique @db.NVarChar(50)
  mobile    String   @db.NVarChar(20)
  email     String   @unique @db.NVarChar(200)
  joined    DateTime
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deals     Deal[]
  user      User?
}

model Deal {
  id        String   @id @default(cuid()) @db.NVarChar(36)
  pospId    String   @db.NVarChar(36)
  posp      Posp     @relation(fields: [pospId], references: [id])
  customer  String   @db.NVarChar(200)
  policy    String   @db.NVarChar(100)
  sum       Float
  premium   Float
  coa       Float
  margin    Float
  /// H = Hot, W = Warm, C = Cold
  status    String   @db.NVarChar(1)
  expected  DateTime
  proposal  String   @db.NVarChar(100)
  policyNo  String   @default("") @db.NVarChar(100)
  issued    DateTime?
  remarks   String   @default("") @db.NVarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String   @id @default(cuid()) @db.NVarChar(36)
  email        String   @unique @db.NVarChar(200)
  passwordHash String   @db.NVarChar(255)
  /// ADMIN | POSP
  role         String   @db.NVarChar(20)
  /// PENDING | ACTIVE | INACTIVE
  status       String   @default("PENDING") @db.NVarChar(20)
  pospId       String?  @unique @db.NVarChar(36)
  posp         Posp?    @relation(fields: [pospId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
