generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Customer {
  id              String    @id @default(cuid()) @db.NVarChar(36)
  name            String    @db.NVarChar(200)
  email           String?   @db.NVarChar(200)
  mobile          String    @unique @db.NVarChar(20)
  alternateMobile String?   @db.NVarChar(20)
  dateOfBirth     DateTime?
  panNumber       String?   @db.NVarChar(20)
  aadharNumber    String?   @db.NVarChar(20)
  
  stateId         String?   @db.NVarChar(20)
  stateName       String?   @db.NVarChar(100)
  districtId      String?   @db.NVarChar(20)
  districtName    String?   @db.NVarChar(100)
  cityId          String?   @db.NVarChar(20)
  cityName        String?   @db.NVarChar(100)
  address         String?   @db.NVarChar(500)
  pincode         String?   @db.NVarChar(10)
  
  /// PENDING | VERIFIED | REJECTED
  kycStatus       String    @default("PENDING") @db.NVarChar(20)
  source          String?   @db.NVarChar(50)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  leads           Lead[]
  deals           Deal[]
  policies        Policy[]
}

model Lead {
  id                String    @id @default(cuid()) @db.NVarChar(36)
  customerId        String    @db.NVarChar(36)
  customer          Customer  @relation(fields: [customerId], references: [id])
  
  assignedToId      String?   @db.NVarChar(36)
  assignedTo        SalesTeam? @relation(fields: [assignedToId], references: [id])

  /// LIFE | HEALTH | MOTOR | PROPERTY | MARINE | TRAVEL | COMMERCIAL | CROP | ENGINEERING
  product           String    @db.NVarChar(100)
  /// Term Life | Whole Life | Endowment | ULIP | Group Life | Individual Mediclaim | Family Floater | etc.
  productSubType    String?   @db.NVarChar(100)
  estimatedPremium  Float
  estimatedSum      Float?
  
  /// THIS_MONTH | T_PLUS_1 | T_PLUS_2 | LATER
  closureTimeline   String    @db.NVarChar(20)
  expectedCloseDate DateTime?
  
  /// NEW | CONTACTED | QUALIFIED | PROPOSAL_SENT | WON | LOST
  status            String    @default("NEW") @db.NVarChar(20)
  
  source            String?   @db.NVarChar(50)
  remarks           String?   @db.NVarChar(500)
  
  convertedToDealId String?   @unique @db.NVarChar(36)
  convertedAt       DateTime?
  
  /// Denormalized hierarchy for fast filtering
  zoneId            String?   @db.NVarChar(50)
  regionId          String?   @db.NVarChar(50)
  areaId            String?   @db.NVarChar(50)
  districtId        String?   @db.NVarChar(50)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model SalesTeam {
  id            String      @id @default(cuid()) @db.NVarChar(36)
  userId        String      @unique @db.NVarChar(36)
  user          User        @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  name          String      @db.NVarChar(200)
  employeeCode  String      @unique @db.NVarChar(50)
  /// ASM | MANAGER | FIELD_AGENT | etc.
  designation   String      @db.NVarChar(50)
  
  managerId     String?     @db.NVarChar(36)
  manager       SalesTeam?  @relation("Hierarchy", fields: [managerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subordinates  SalesTeam[] @relation("Hierarchy")
  
  territory     String?     @db.NVarChar(100)
  mobile        String      @db.NVarChar(20)
  email         String      @db.NVarChar(200)
  joiningDate   DateTime
  
  /// Explicit territory assignments for hierarchy scope
  zoneId        String?     @db.NVarChar(50)
  zoneName      String?     @db.NVarChar(100)
  regionId      String?     @db.NVarChar(50)
  regionName    String?     @db.NVarChar(100)
  areaId        String?     @db.NVarChar(50)
  areaName      String?     @db.NVarChar(100)
  
  /// ACTIVE | INACTIVE | ON_LEAVE
  status        String      @default("ACTIVE") @db.NVarChar(20)
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  pospsManaged  Posp[]      @relation("ASMManaged")
  leadsAssigned Lead[]
}

model Posp {
  id             String     @id @default(cuid()) @db.NVarChar(36)
  /// UserId from Cognitensor ListPospData (null until synced)
  externalId     String?    @unique @db.NVarChar(50)
  /// HephGcdCode from Cognitensor (e.g. GIDROINET2000473)
  gcdCode        String?    @db.NVarChar(100)
  name           String     @db.NVarChar(200)
  code           String     @unique @db.NVarChar(50)
  mobile         String     @db.NVarChar(20)
  email          String     @unique @db.NVarChar(200)
  joined         DateTime
  active         Boolean    @default(true)
  
  asmId          String?    @db.NVarChar(36)
  asm            SalesTeam? @relation("ASMManaged", fields: [asmId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  lastBusinessAt DateTime?
  autoInactive   Boolean    @default(false)
  region         String?    @db.NVarChar(100)
  
  /// Hierarchy territory IDs for scoped filtering
  zoneId         String?    @db.NVarChar(50)
  regionId       String?    @db.NVarChar(50)
  areaId         String?    @db.NVarChar(50)
  districtId     String?    @db.NVarChar(50)
  /// Cognitensor geography IDs — synced from ListPospData on SSO login
  stateId        String?    @db.NVarChar(50)
  cityId         String?    @db.NVarChar(50)
  
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deals          Deal[]
  user           User?
}

model Deal {
  id         String    @id @default(cuid()) @db.NVarChar(36)
  pospId     String?   @db.NVarChar(36)
  posp       Posp?     @relation(fields: [pospId], references: [id])
  
  customerId String?   @db.NVarChar(36)
  customer   Customer? @relation(fields: [customerId], references: [id])
  customerName String  @default("") @db.NVarChar(200)
  
  policy     String    @db.NVarChar(100)
  /// LIFE | HEALTH | MOTOR | PROPERTY | MARINE | TRAVEL | COMMERCIAL | CROP | ENGINEERING
  productLine String?  @db.NVarChar(50)
  /// Term Life | Family Floater | Comprehensive | etc.
  productSubType String? @db.NVarChar(100)
  /// Insurer name: LIC | HDFC Life | ICICI Prudential | Star Health | etc.
  insurer    String?   @db.NVarChar(100)
  sum        Float
  premium    Float
  /// Raw COA value as entered (interpret with coaType)
  coa        Float
  /// COA entry mode: PERCENT (of premium) | AMOUNT (rupees)
  coaType    String    @default("AMOUNT") @db.NVarChar(10)
  /// Computed effective COA in rupees — use this for aggregations
  coaAmount  Float     @default(0)
  margin     Float
  /// H = Hot, W = Warm, C = Cold
  status     String    @db.NVarChar(1)
  expected   DateTime
  proposal   String    @db.NVarChar(100)
  policyNo   String    @default("") @db.NVarChar(100)
  issued     DateTime?
  remarks    String    @default("") @db.NVarChar(500)
  
  /// Denormalized hierarchy for fast role-based filtering
  zoneId     String?   @db.NVarChar(50)
  regionId   String?   @db.NVarChar(50)
  areaId     String?   @db.NVarChar(50)
  districtId String?   @db.NVarChar(50)
  
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Policy {
  id                 String    @id @default(cuid()) @db.NVarChar(36)
  policyNumber       String    @unique @db.NVarChar(100)
  customerId         String    @db.NVarChar(36)
  customer           Customer  @relation(fields: [customerId], references: [id])
  /// LIFE | HEALTH | MOTOR | PROPERTY | MARINE | TRAVEL | COMMERCIAL | CROP | ENGINEERING
  product            String    @db.NVarChar(100)
  /// Term Life | Family Floater | Comprehensive | etc.
  productSubType     String?   @db.NVarChar(100)
  /// Insurer name
  insurer            String?   @db.NVarChar(100)
  premium            Float
  sumAssured         Float
  issueDate          DateTime
  rewardPoints       Int       @default(0)
  paymentReleaseDate DateTime?
  /// PENDING | RELEASED | PAID
  paymentStatus      String    @default("PENDING") @db.NVarChar(20)
  /// SYNCED | PENDING | FAILED
  sapSyncStatus      String    @default("PENDING") @db.NVarChar(20)
  sapSyncAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model User {
  id           String     @id @default(cuid()) @db.NVarChar(36)
  email        String     @unique @db.NVarChar(200)
  passwordHash String     @db.NVarChar(255)
  /// SUPER_ADMIN | NATIONAL_HEAD | ZH | RH | ASM | DM | POSP
  role         String     @db.NVarChar(20)
  /// PENDING | ACTIVE | INACTIVE
  status       String     @default("PENDING") @db.NVarChar(20)
  pospId       String?    @unique @db.NVarChar(36)
  posp         Posp?      @relation(fields: [pospId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  salesTeam    SalesTeam?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

/// One row per distinct person across all Cognitensor ListHierarchyUserData
/// district chains. Keyed by Cognitensor UserId. `role` is a label derived from
/// `userType` (see user-type.util.ts) and is NOT tied to a column position —
/// the same person can sit at different chain depths in different districts.
model OrgMember {
  id       String  @id @default(cuid()) @db.NVarChar(36)
  /// Cognitensor UserId — stable strong key for a person.
  userId   String  @unique @db.NVarChar(50)
  /// Cognitensor UserCode — matches SalesTeam.employeeCode / Posp.code.
  userCode String  @db.NVarChar(100)
  userName String? @db.NVarChar(200)
  /// Raw Cognitensor usertype (0=ADMIN,4=ASM,6=RH,10=ZH,11=ASSISTASM,12=CH,14=SZH,...).
  userType Int?
  /// Derived role label: ADMIN | CMF | CSF | CSP | ASM | RH | ZH | ASSISTASM | CH | SZH | UNKNOWN
  role     String  @db.NVarChar(20)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userCode])
  @@index([role])
}

model Announcement {
  id          String   @id @default(cuid()) @db.NVarChar(36)
  title       String   @db.NVarChar(200)
  content     String   @db.NVarChar(2000)
  /// Comma-separated target roles e.g. "POSP,DM,ASM"
  targetRoles String   @db.NVarChar(200)
  /// "info" | "warning" | "success" | "error"
  severity    String   @default("info") @db.NVarChar(20)
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  startsAt    DateTime
  expiresAt   DateTime?
  createdBy   String   @db.NVarChar(36)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  dismissals  AnnouncementDismissal[]
}

model AnnouncementDismissal {
  id             String       @id @default(cuid()) @db.NVarChar(36)
  announcementId String       @db.NVarChar(36)
  userId         String       @db.NVarChar(36)
  dismissedAt    DateTime     @default(now())

  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([announcementId, userId])
}

/// District-keyed management chain mirrored from Cognitensor ListHierarchyUserData.
/// One row per district; a manager covers a district when their code appears in
/// the column for their level. This is the source of truth for hierarchy scoping:
/// a POSP belongs to a district (Posp.districtId), and the chain above that
/// district (DM -> ASM -> RH -> ZH -> NH) determines who can see that POSP.
model DistrictHierarchy {
  id           String  @id @default(cuid()) @db.NVarChar(36)
  districtId   String  @unique @db.NVarChar(50)
  districtName String? @db.NVarChar(200)
  stateId      String? @db.NVarChar(50)

  dmId   String? @db.NVarChar(50)
  dmCode String? @db.NVarChar(100)
  dmName String? @db.NVarChar(200)

  asmId   String? @db.NVarChar(50)
  asmCode String? @db.NVarChar(100)
  asmName String? @db.NVarChar(200)

  rhId   String? @db.NVarChar(50)
  rhCode String? @db.NVarChar(100)
  rhName String? @db.NVarChar(200)

  zhId   String? @db.NVarChar(50)
  zhCode String? @db.NVarChar(100)
  zhName String? @db.NVarChar(200)

  nhId   String? @db.NVarChar(50)
  nhCode String? @db.NVarChar(100)
  nhName String? @db.NVarChar(200)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([districtId])
}

/// Adjacency list: `memberId` reports to `managerId` (one step up the chain).
/// Deduplicated — a person reporting to the same manager across many districts
/// collapses to a single edge.
model OrgEdge {
  id        String @id @default(cuid()) @db.NVarChar(36)
  memberId  String @db.NVarChar(36)
  managerId String @db.NVarChar(36)

  createdAt DateTime @default(now())

  @@unique([memberId, managerId])
  @@index([managerId])
  @@index([memberId])
}

/// Transitive closure of OrgEdge. `ancestorId` sits above `descendantId` at
/// `depth` steps (depth 0 = self). Enables O(1)-ish subtree reads and org-chart
/// rendering without recursion. Rebuilt weekly alongside the rest of the graph.
model OrgClosure {
  id           String @id @default(cuid()) @db.NVarChar(36)
  ancestorId   String @db.NVarChar(36)
  descendantId String @db.NVarChar(36)
  depth        Int

  createdAt DateTime @default(now())

  @@unique([ancestorId, descendantId])
  @@index([ancestorId])
  @@index([descendantId])
}

/// Bridge from the people-graph to geography/business. One row per (district,
/// member) for every member that appears anywhere in that district's chain
/// (owner + all R-levels). A manager's scope is every district they cover here,
/// which already encodes transitive coverage — no closure walk needed.
model DistrictChain {
  id           String  @id @default(cuid()) @db.NVarChar(36)
  districtId   String  @db.NVarChar(50)
  districtName String? @db.NVarChar(200)
  stateId      String? @db.NVarChar(50)
  /// Cognitensor zone/region the district belongs to (from ListDistrict).
  zoneId       String? @db.NVarChar(50)
  zoneName     String? @db.NVarChar(200)
  regionId     String? @db.NVarChar(50)
  regionName   String? @db.NVarChar(200)
  memberId     String  @db.NVarChar(36)
  /// 0 = district owner (DistrictManager), 1 = R1, 2 = R2, ...
  chainLevel   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([districtId, memberId])
  @@index([memberId])
  @@index([districtId])
  @@index([stateId])
  @@index([zoneId])
  @@index([regionId])
}
